<?xml version="1.0"?>
<package format="3">
  <name>paren_conditions</name>
  <version>1.0.0</version>
  <description>Package with parenthesised conditions</description>
  <maintainer email="x@x.com">X</maintainer>
  <license>Apache-2.0</license>

  <!-- (false or true) and true = true -->
  <depend condition="($ROS_VERSION == 1 or $ROS_VERSION == 2) and $ROS_VERSION == 2">rclcpp</depend>

  <!-- (false or true) and false = false -->
  <depend condition="($ROS_VERSION == 1 or $ROS_VERSION == 2) and $ROS_VERSION == 1">roscpp</depend>

  <!-- Unconditional -->
  <depend>std_msgs</depend>
</package>
